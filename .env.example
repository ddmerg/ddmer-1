# ===== Database (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# ===== R2 Object Storage (Cloudflare) =====
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=kirameku-files
# Optional: custom public URL for R2 (e.g., CDN domain)
# R2_PUBLIC_URL=https://your-r2-cdn.example.com

# ===== JWT Secret =====
SECRET_KEY=your-secret-key-at-least-32-characters

# ===== GitHub OAuth =====
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
ADMIN_GITHUB_USERS=your_github_username

# ===== Frontend =====
FRONTEND_ORIGIN=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com

# ===== Optional: Novel API (reader-master) =====
# NEXT_PUBLIC_NOVEL_API_URL=http://your-server:18080
# NOVEL_API_URL=http://your-server:18080

# ===== Optional: Resend Email =====
# RESEND_API_KEY=re_xxxxx
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_NOVEL_API_URL=http://your-server:18080
NOVEL_API_URL=http://your-server:18080
