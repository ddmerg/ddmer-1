# =============================================
# ddmer-1 博客 Nginx 反向代理配置
# 使用方法：
#   1. 复制此文件到 /etc/nginx/sites-available/ddmer-blog
#   2. 修改 server_name 和 ssl_certificate 路径
#   3. 创建软链接：ln -s /etc/nginx/sites-available/ddmer-blog /etc/nginx/sites-enabled/
#   4. 测试配置：nginx -t
#   5. 重载 Nginx：nginx -s reload
# =============================================

# HTTP → HTTPS 重定向
server {
    listen 80;
    server_name 你的域名.com;
    return 301 https://$server_name$request_uri;
}

# HTTPS 主配置
server {
    listen 443 ssl http2;
    server_name 你的域名.com;

    # SSL 证书路径（用 certbot 申请后会自动生成）
    ssl_certificate     /etc/letsencrypt/live/你的域名.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/你的域名.com/privkey.pem;

    # SSL 安全设置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # 反向代理到 Next.js
    location / {
        proxy_pass http://127.0.0.1:3000;

        # 传递客户端真实 IP
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 关键：禁用 Nginx 代理缓存，否则部署后会返回旧 HTML
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        proxy_cache off;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";

        # 超时设置
        proxy_connect_timeout 30s;
        proxy_read_timeout 86400s;
        proxy_send_timeout 30s;

        # WebSocket 支持（开发时热更新用）
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # 静态资源缓存（Next.js 产物，带 hash 文件名）
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # 文件上传大小限制
    client_max_body_size 50M;
}
